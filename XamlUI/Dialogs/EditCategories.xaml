<Window x:Class="XamlUI.Dialogs.EditCategories"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:XamlUI.Dialogs"
        xmlns:w="clr-namespace:XamlUI.UserControls"
        xmlns:t="clr-namespace:XamlUI.Tools"
        mc:Ignorable="d"
        Title="Edit Categories"
        Icon="/XamlUI;component/Images/Bananas.ico"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        SizeToContent="WidthAndHeight">
    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="Margin" Value="3"/>
        </Style>
        <t:FontWeightConverter x:Key="fontWeightConverter"/>
    </Window.Resources>
    <DockPanel>
        <!-- Done panel -->
        <w:DonePanel DockPanel.Dock="Bottom"/>

        <!-- Main panel -->
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Row 0: Listbox of categories -->
            <ListView
                x:Name="listView"
                Height="300" Width="670" Grid.ColumnSpan="4"
                SelectionMode="Single"
                ItemsSource="{Binding CategoriesSource}"
                SelectedItem="{Binding SelectedCategory, Mode=TwoWay}"
                MouseDoubleClick="OnListviewDoubleClick">

                <ListView.View>
                    <GridView>
                        <GridViewColumn Header="Name" Width="200">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding CategoryItem.IndentedName}" FontWeight="{Binding CategoryItem.FontWeight, Converter={StaticResource fontWeightConverter}}" />
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                        <GridViewColumn Header="Type" Width="70">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding CategoryItem.TypeString}" Foreground="Blue" />
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                        <GridViewColumn Header="Description" Width="220" DisplayMemberBinding="{Binding CategoryItem.Description}"/>
                        <GridViewColumn Header="Tax Info" Width="150" DisplayMemberBinding="{Binding CategoryItem.TaxInfo}"/>
                    </GridView>
                </ListView.View>
            </ListView>

            <!-- Row 1: Control buttons -->
            <Button
                Grid.Column="0" Grid.Row="1"
                Content="Add..." Command="{Binding AddCategory}"/>
            <Button
                Grid.Column="1" Grid.Row="1"
                Content="Edit..." Command="{Binding EditCategory}"/>
            <Button
                Grid.Column="2" Grid.Row="1"
                Content="Delete" Command="{Binding DeleteCategory}"/>
            <StackPanel
                Grid.Column="3" Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Stretch">
                <TextBlock Text="Show:" VerticalAlignment="Center" Margin="5,0"/>
                <ComboBox 
                    HorizontalAlignment="Stretch" Margin="0,3" Width="150"
                    ItemsSource="{Binding ShowSource, Mode=OneTime}" SelectedItem="{Binding Show, Mode=TwoWay}" />
            </StackPanel>
        </Grid>
    </DockPanel>
</Window>
