<Window x:Class="XamlUI.Dialogs.Reports.SearchResult"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:XamlUI.Dialogs.Reports"
        xmlns:ucs="clr-namespace:XamlUI.UserControls"
        xmlns:w="clr-namespace:XamlUI.Widgets"
        mc:Ignorable="d"
        Title="Search results"
        Icon="/XamlUI;component/Images/Bananas.ico"
        WindowStartupLocation="CenterOwner"
        Width="800" Height="340"
        SizeToContent="WidthAndHeight">
    <DockPanel>

        <!-- Controls search -->
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" HorizontalAlignment="Right">
            <w:WatermarkTextBox x:Name="searchTextBox" Style="{StaticResource FormWatermarkTextBox}" 
                                Watermark="Search text" Text="{Binding SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="80">
                <TextBox.InputBindings>
                    <KeyBinding Key="Return" 
                            Command="{Binding Search, UpdateSourceTrigger=PropertyChanged}"
                            CommandParameter="{Binding ElementName=searchTextBox, Path=Text}"/>
                </TextBox.InputBindings>
            </w:WatermarkTextBox>

            <Button Style="{StaticResource FormButton}" Content="Search" Width="75"
                    Command="{Binding Search}" CommandParameter="{Binding ElementName=searchTextBox, Path=Text}"/>
            <Button Style="{StaticResource FormButton}" Content="Print..." Width="75" Click="OnPrintClick"/>
            <Button Style="{StaticResource FormButton}" Content="Close" Width="75" IsCancel="True"/>
        </StackPanel>

        <!-- Main panel -->
        <ListView
            SelectionMode="Single"
            MouseDoubleClick="OnListViewMouseDoubleClick"
            ItemsSource="{Binding FoundItemsSource}">

            <ListView.View>
                <GridView>
                    <GridViewColumn Header="Account" Width="140" DisplayMemberBinding="{Binding Account}"/>
                    <GridViewColumn Header="Date" Width="80" DisplayMemberBinding="{Binding Date, StringFormat=MM/dd/yyyy}"/>
                    <GridViewColumn Header="Payee" Width="180" DisplayMemberBinding="{Binding Payee}"/>
                    <GridViewColumn Header="Memo" Width="180" DisplayMemberBinding="{Binding Memo}"/>
                    <GridViewColumn Header="Category" Width="120" DisplayMemberBinding="{Binding Category}"/>
                    <GridViewColumn Header="Amount" Width="80">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Amount, StringFormat=N2}" TextAlignment="Right"/>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                </GridView>
            </ListView.View>
        </ListView>

    </DockPanel>
</Window>
