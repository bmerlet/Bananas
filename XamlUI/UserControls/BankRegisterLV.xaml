<UserControl x:Class="XamlUI.UserControls.BankRegisterLV"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:XamlUI.UserControls"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <Label Content="{Binding AccountName}"/>

        <ListView
            Name="listView"
            Grid.Row="1"
            AlternationCount="2"
            SelectionMode="Single"
            ItemsSource="{Binding Transactions}">

            <!-- Make the list view items use all the horizontal space -->
            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                </Style>
            </ListView.ItemContainerStyle>
            
            <ListView.View>
                <GridView>

                    <!-- Date column -->
                    <GridViewColumn Width="{Binding WidthOfDateColumn, Mode=TwoWay}">

                        <GridViewColumn.Header>
                            <GridViewColumnHeader Content="Date" Tag="Date" Click="OnColumnHeaderClicked"/>
                        </GridViewColumn.Header>
                        
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <Grid>
                                    <TextBlock x:Name="dateTextBlock" Text="{Binding Path=Date, StringFormat=M/d/yyyy}"/>
                                    <local:DateBox x:Name="dateBox" Date="{Binding Path=Date, Mode=TwoWay}"/>
                                </Grid>
                                <DataTemplate.Triggers>
                                    <DataTrigger Binding="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType={x:Type ListViewItem}}, Path=IsSelected}" Value="True">
                                        <Setter TargetName="dateTextBlock" Property="Visibility" Value="Collapsed"/>
                                        <Setter TargetName="dateBox" Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType={x:Type ListViewItem}}, Path=IsSelected}" Value="False">
                                        <Setter TargetName="dateTextBlock" Property="Visibility" Value="Visible"/>
                                        <Setter TargetName="dateBox" Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </DataTemplate.Triggers>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>

                    <!-- Medium column -->
                    <GridViewColumn Width="{Binding WidthOfMediumColumn, Mode=TwoWay}">

                        <GridViewColumn.Header>
                            <GridViewColumnHeader Content="Type" Tag="Medium" Click="OnColumnHeaderClicked"/>
                        </GridViewColumn.Header>

                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <Grid>
                                    <TextBlock x:Name="mediumTextBlock" Text="{Binding Medium}"/>
                                    <ComboBox x:Name="mediumComboBox" ItemsSource="{Binding MediumSource}" SelectedItem="{Binding Path=Medium, Mode=TwoWay}"/>
                                </Grid>
                                <DataTemplate.Triggers>
                                    <DataTrigger Binding="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType={x:Type ListViewItem}}, Path=IsSelected}" Value="True">
                                        <Setter TargetName="mediumTextBlock" Property="Visibility" Value="Collapsed"/>
                                        <Setter TargetName="mediumComboBox" Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType={x:Type ListViewItem}}, Path=IsSelected}" Value="False">
                                        <Setter TargetName="mediumTextBlock" Property="Visibility" Value="Visible"/>
                                        <Setter TargetName="mediumComboBox" Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </DataTemplate.Triggers>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                    
                    <!-- Payee column -->
                    <GridViewColumn Width="{Binding WidthOfPayeeColumn, Mode=TwoWay}">

                        <GridViewColumn.Header>
                            <GridViewColumnHeader Content="Payee" Tag="Payee" Click="OnColumnHeaderClicked"/>
                        </GridViewColumn.Header>

                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <Grid>
                                    <TextBlock x:Name="payeeTextBlock" Text="{Binding Path=Payee}"/>
                                    <local:AutoCompleteTextBox 
                                        x:Name="payeeACBox"
                                        Text="{Binding Payee, Mode=TwoWay}"
                                        Watermark="Payee"
                                        DisplayMember="Payee"
                                        ListBoxHeight="150" 
                                        ItemsSource="{Binding Payees}">
                                        <local:AutoCompleteTextBox.ItemTemplate>
                                            <DataTemplate>
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="120"/>
                                                        <ColumnDefinition Width="65"/>
                                                        <ColumnDefinition Width="120"/>
                                                        <ColumnDefinition Width="100"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Text="{Binding Payee}"/>
                                                    <TextBlock Text="{Binding Amount}"   Grid.Column="1" Margin="3,0" HorizontalAlignment="Right" Foreground="Red"/>
                                                    <TextBlock Text="{Binding Category}" Grid.Column="2" Foreground="Blue"/>
                                                    <TextBlock Text="{Binding Memo}"     Grid.Column="3" Margin="3,0,0,0"/>
                                                </Grid>
                                            </DataTemplate>
                                        </local:AutoCompleteTextBox.ItemTemplate>
                                    </local:AutoCompleteTextBox>
                                </Grid>
                                <DataTemplate.Triggers>
                                    <DataTrigger Binding="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType={x:Type ListViewItem}}, Path=IsSelected}" Value="True">
                                        <Setter TargetName="payeeTextBlock" Property="Visibility" Value="Collapsed"/>
                                        <Setter TargetName="payeeACBox" Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType={x:Type ListViewItem}}, Path=IsSelected}" Value="False">
                                        <Setter TargetName="payeeTextBlock" Property="Visibility" Value="Visible"/>
                                        <Setter TargetName="payeeACBox" Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </DataTemplate.Triggers>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                    
                    <!-- Memo column-->
                    <!-- Category column-->
                    <!-- Payment column-->
                    <!-- Status column-->
                    <!-- Deposit column-->

                    <!-- Balance column-->
                    <GridViewColumn Header="Balance" Width="{Binding WidthOfBalanceColumn, Mode=TwoWay}">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding BalanceString, Mode=OneWay}" HorizontalAlignment="Right"/>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                </GridView>
            </ListView.View>
        </ListView>

    </Grid>
</UserControl>
