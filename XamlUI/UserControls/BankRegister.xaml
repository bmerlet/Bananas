<UserControl x:Class="XamlUI.UserControls.BankRegister"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:XamlUI.UserControls"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid>

        <Grid.Resources>
            
            <!-- Templates for the date column -->
            <DataTemplate x:Key="DateColumnTemplate">
                <TextBlock Text="{Binding Date, StringFormat=M/d/yyyy}"/>
            </DataTemplate>
            <DataTemplate x:Key="DateEditingColumnTemplate">
                <local:DateBox Date="{Binding Date, Mode=TwoWay}"/>
            </DataTemplate>

            <!-- Templates for the check number column -->
            <DataTemplate x:Key="CheckNumberColumnTemplate">
                <TextBlock Text="{Binding Type}"/>
            </DataTemplate>
            <DataTemplate x:Key="CheckNumberEditingColumnTemplate">
                <ComboBox IsEditable="True" Text="{Binding Type, Mode=TwoWay}" ItemsSource="{Binding TypeSource}"/>
            </DataTemplate>

            <!-- Templates for the payee column -->
            <DataTemplate x:Key="PayeeColumnTemplate">
                <TextBlock Text="{Binding Payee}"/>
            </DataTemplate>
            <DataTemplate x:Key="PayeeEditingColumnTemplate">
                <local:AutoCompleteTextBox 
                    Text="{Binding Payee, Mode=TwoWay}"
                    Watermark="Payee"
                    DisplayMember="Payee"
                    ListBoxHeight="150" 
                    ItemsSource="{Binding Payees}">
                    <local:AutoCompleteTextBox.ItemTemplate>
                        <DataTemplate>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="65"/>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="100"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{Binding Payee}"/>
                                <TextBlock Text="{Binding Amount}"   Grid.Column="1" Margin="3,0" HorizontalAlignment="Right" Foreground="Red"/>
                                <TextBlock Text="{Binding Category}" Grid.Column="2" Foreground="Blue"/>
                                <TextBlock Text="{Binding Memo}"     Grid.Column="3" Margin="3,0,0,0"/>
                            </Grid>
                        </DataTemplate>
                    </local:AutoCompleteTextBox.ItemTemplate>
                </local:AutoCompleteTextBox>
            </DataTemplate>

            <!-- Templates for the payment column -->
            <DataTemplate x:Key="PaymentColumnTemplate">
                <TextBlock Text="{Binding PaymentString}" TextAlignment="Right"/>
            </DataTemplate>
            <DataTemplate x:Key="PaymentEditingColumnTemplate">
                <local:AmountBox Amount="{Binding Payment, Mode=TwoWay}" TextAlignment="Right"/>
            </DataTemplate>

            <!-- Templates for the deposit column -->
            <DataTemplate x:Key="DepositColumnTemplate">
                <TextBlock Text="{Binding DepositString}" TextAlignment="Right"/>
            </DataTemplate>
            <DataTemplate x:Key="DepositEditingColumnTemplate">
                <local:AmountBox Amount="{Binding Deposit, Mode=TwoWay}" TextAlignment="Right"/>
            </DataTemplate>

        </Grid.Resources>
        
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <Label Content="{Binding AccountName}"/>

        <DataGrid
            Name="dataGrid"
            Grid.Row="1"
            AlternatingRowBackground = "LightBlue" AlternationCount = "2"
            AutoGenerateColumns="False"
            SelectionMode="Single"
            SelectionUnit="FullRow"
            CanUserAddRows="False"
            CanUserDeleteRows="True"
            ItemsSource="{Binding Transactions}">

            <DataGrid.Columns>
                <!-- Date column -->
                <DataGridTemplateColumn
                    Header="Date"
                    CellTemplate="{StaticResource DateColumnTemplate}"
                    CellEditingTemplate="{StaticResource DateEditingColumnTemplate}"/>

                <!-- Type column  -->
                <DataGridTemplateColumn
                    Header="Check#"
                    CellTemplate="{StaticResource CheckNumberColumnTemplate}"
                    CellEditingTemplate="{StaticResource CheckNumberEditingColumnTemplate}"/>

                <!-- Payee column -->
                <DataGridTemplateColumn
                    Header="Payee"
                    CellTemplate="{StaticResource PayeeColumnTemplate}"
                    CellEditingTemplate="{StaticResource PayeeEditingColumnTemplate}" />

                <!-- Memo column -->
                <DataGridTextColumn Header="Memo" Binding="{Binding Memo, Mode=TwoWay}"/>
                
                <!-- ZZZ make an autocomplete -->
                <DataGridTextColumn Header="Category" Binding="{Binding Category}"/>

                <!-- Payment column  -->
                <DataGridTemplateColumn
                    Header="Payment"
                    CellTemplate="{StaticResource PaymentColumnTemplate}"
                    CellEditingTemplate="{StaticResource PaymentEditingColumnTemplate}"/>

                <!-- Status column  -->
                <DataGridComboBoxColumn Header="Status" SelectedItemBinding="{Binding Status, Mode=TwoWay}">
                    <DataGridComboBoxColumn.ElementStyle>
                        <Style TargetType="{x:Type ComboBox}">
                            <Setter Property="ItemsSource" Value="{Binding Path=StatusSource}" />
                        </Style>
                    </DataGridComboBoxColumn.ElementStyle>
                    <DataGridComboBoxColumn.EditingElementStyle>
                        <Style TargetType="{x:Type ComboBox}">
                            <Setter Property="ItemsSource" Value="{Binding Path=StatusSource}" />
                        </Style>
                    </DataGridComboBoxColumn.EditingElementStyle>
                    
                </DataGridComboBoxColumn>

                <!-- Deposit column  -->
                <DataGridTemplateColumn
                    Header="Deposit"
                    CellTemplate="{StaticResource DepositColumnTemplate}"
                    CellEditingTemplate="{StaticResource DepositEditingColumnTemplate}"/>

                <!-- Balance column  -->
                <DataGridTextColumn Header="Balance" Binding="{Binding Balance}" IsReadOnly="True">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="{x:Type TextBlock}">
                            <Setter Property="HorizontalAlignment" Value="Right" />
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

            </DataGrid.Columns>
            
        </DataGrid>
    </Grid>
</UserControl>
