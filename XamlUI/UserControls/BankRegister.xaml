<UserControl x:Class="XamlUI.UserControls.BankRegister"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:XamlUI.UserControls"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid>

        <Grid.Resources>
            
            <!-- Templates for the date column -->
            <DataTemplate x:Key="DateColumnTemplate">
                <TextBlock Text="{Binding Date, StringFormat=MM/dd/yyyy}"/>
            </DataTemplate>
            <DataTemplate x:Key="DateEditingColumnTemplate">
                <local:DateTextBox Date="{Binding Date, Mode=TwoWay}"/>
            </DataTemplate>
            
            <!-- Templates for the payee column -->
            <DataTemplate x:Key="PayeeColumnTemplate">
                <TextBlock Text="{Binding Payee, Mode=TwoWay}"/>
            </DataTemplate>
            <DataTemplate x:Key="PayeeEditingColumnTemplate">
                <local:AutoCompleteTextBox 
                    Text="{Binding Payee}" 
                    ListBoxHeight="150" 
                    ListBoxItemsSource="{Binding Payees}">
                    <local:AutoCompleteTextBox.ListBoxItemTemplate>
                        <DataTemplate>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="65"/>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="100"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{Binding Payee}"/>
                                <TextBlock Text="{Binding Amount}"   Grid.Column="1" Margin="3,0" HorizontalAlignment="Right" Foreground="Red"/>
                                <TextBlock Text="{Binding Category}" Grid.Column="2" Foreground="Blue"/>
                                <TextBlock Text="{Binding Memo}"     Grid.Column="3" Margin="3,0,0,0"/>
                            </Grid>
                        </DataTemplate>
                    </local:AutoCompleteTextBox.ListBoxItemTemplate>
                </local:AutoCompleteTextBox>
            </DataTemplate>
        </Grid.Resources>
        
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <Label Content="{Binding AccountName}"/>

        <DataGrid
            Name="dataGrid"
            Grid.Row="1"
            AlternatingRowBackground = "LightBlue" AlternationCount = "2"
            AutoGenerateColumns="False"
            ItemsSource="{Binding Transactions}">

            <DataGrid.Columns>
                <!-- Date column -->
                <DataGridTemplateColumn
                    Header="Date"
                    CellTemplate="{StaticResource DateColumnTemplate}"
                    CellEditingTemplate="{StaticResource DateEditingColumnTemplate}"/>

                <!-- Type column -->
                <DataGridTextColumn Header="Type" Binding="{Binding Type}"/>

                <!-- Payee column -->
                <DataGridTemplateColumn
                    Header="Payee"
                    CellTemplate="{StaticResource PayeeColumnTemplate}"
                    CellEditingTemplate="{StaticResource PayeeEditingColumnTemplate}" />

                <DataGridTextColumn Header="Memo" Binding="{Binding Memo}"/>
                <DataGridTextColumn Header="Category" Binding="{Binding Category}"/>
                <DataGridTextColumn Header="Payment" Binding="{Binding Payment}"/>
                <DataGridTextColumn Header="Status" Binding="{Binding Status}"/>
                <DataGridTextColumn Header="Deposit" Binding="{Binding Deposit}"/>
                <DataGridTextColumn Header="Balance" Binding="{Binding Balance}" IsReadOnly="True"/>
            </DataGrid.Columns>
            
        </DataGrid>
    </Grid>
</UserControl>
