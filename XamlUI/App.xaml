<Application x:Class="XamlUI.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:XamlUI"
             xmlns:ucs="clr-namespace:XamlUI.UserControls"
             xmlns:t="clr-namespace:XamlUI.Tools"
             StartupUri="MainWindow.xaml">
    <Application.Resources>

        <!--
          == Buttons ==
          -->

        <!-- OK button -->
        <Style TargetType="Button" x:Key="OKButton">
            <Setter Property="Content" Value="OK"/>
            <Setter Property="IsDefault" Value="True"/>
            <Setter Property="HorizontalAlignment" Value="Left"/>
            <Setter Property ="VerticalAlignment" Value="Center"/>
            <Setter Property="Width" Value="75" />
            <Setter Property="Margin" Value="0,0,10,0" />
        </Style>

        <!-- Cancel button -->
        <Style TargetType="Button" x:Key="CancelButton">
            <Setter Property="Content" Value="Cancel"/>
            <Setter Property="IsCancel" Value="True"/>
            <Setter Property="HorizontalAlignment" Value="Left"/>
            <Setter Property ="VerticalAlignment" Value="Center"/>
            <Setter Property="Width" Value="75" />
            <Setter Property="Margin" Value="0,0,10,0" />
        </Style>

        <!-- Done button -->
        <Style TargetType="Button" x:Key="DoneButton">
            <Setter Property="Content" Value="Done"/>
            <Setter Property="IsDefault" Value="True"/>
            <Setter Property="IsCancel" Value="True"/>
            <Setter Property="HorizontalAlignment" Value="Left"/>
            <Setter Property ="VerticalAlignment" Value="Center"/>
            <Setter Property="Width" Value="75" />
            <Setter Property="Margin" Value="0,0,10,0" />
        </Style>

        <!-- Style for category autocomplete textbox -->
        <t:FontWeightConverter x:Key="fontWeightConverter"/>
        <Style TargetType="{x:Type ucs:AutoCompleteTextBox}" x:Key="CategoryBoxStyle">
            <Setter Property="Watermark" Value="Category"/>
            <Setter Property="DisplayMember" Value="FullName"/>
            <Setter Property="ListBoxHeight" Value="150"/>
            <Setter Property="ListBoxWidth" Value="200"/>
            <Setter Property="ItemTemplate">
                <Setter.Value>
                    <DataTemplate>
                        <TextBlock Text="{Binding IndentedName}" FontWeight="{Binding FontWeight, Converter={StaticResource fontWeightConverter}}" />
                    </DataTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <!-- Style for payee autocomplete textbox-->
        <Style TargetType="{x:Type ucs:AutoCompleteTextBox}" x:Key="PayeeBoxStyle">
            <Setter Property="Watermark" Value="Payee"/>
            <Setter Property="DisplayMember" Value="Payee"/>
            <Setter Property="ListBoxHeight" Value="150"/>
            <Setter Property="ItemTemplate">
                <Setter.Value>
                    <DataTemplate>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="65"/>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="100"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="{Binding Payee}"/>
                            <TextBlock Text="{Binding Amount}"   Grid.Column="1" Margin="3,0" HorizontalAlignment="Right" Foreground="Red"/>
                            <TextBlock Text="{Binding Category}" Grid.Column="2" Foreground="Blue"/>
                            <TextBlock Text="{Binding Memo}"     Grid.Column="3" Margin="3,0,0,0"/>
                        </Grid>
                    </DataTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Application.Resources>
</Application>
